# Database Configuration
DB_NAME=lma_chatbot_prod
DB_USER=lma_user
DB_PASSWORD=${DB_PASSWORD}
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://lma_user:${DB_PASSWORD}@postgres:5432/lma_chatbot_prod

# API Configuration
API_PORT=8000
ENVIRONMENT=production
LOG_LEVEL=WARNING

# Frontend Configuration
REACT_APP_API_URL=https://api.lma-agent.com
CLIENT_PORT=443

# Redis Configuration
REDIS_PORT=6379

# API Keys (production values - set via secrets)
OPENAI_API_KEY=${OPENAI_API_KEY}
GOOGLE_API_KEY=${GOOGLE_API_KEY}

# LLM Configuration
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=4096

# RAG Configuration
VECTOR_DB_PATH=/data/vector_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Logging
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/logs/app.log
